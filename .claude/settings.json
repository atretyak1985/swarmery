{
  "enabledPlugins": {
    "core@swarmery": true,
    "graphify-pack@swarmery": true,
    "architecture-pack@swarmery": true
  },
  "env": {
    "AGENT_PROJECT": "swarmery"
  },
  "extraKnownMarketplaces": {
    "swarmery": {
      "source": {
        "repo": "atretyak1985/swarmery",
        "source": "github"
      }
    }
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)"
    ]
  },
  "statusLine": {
    "command": "bash $CLAUDE_PROJECT_DIR/plugins/core/statusline/statusline.sh",
    "type": "command"
  }
}
